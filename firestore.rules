rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // subscribers collection
    // - Anyone can create a new subscriber document (public sign-up)
    // - A subscriber can update their own document (edit details, unsubscribe)
    // - No reads allowed from the client — subscriber list stays server-side only
    match /subscribers/{subscriberId} {
      allow create: if request.resource.data.keys().hasAll(['id', 'email', 'active', 'subscribedAt'])
                    && request.resource.data.email is string
                    && request.resource.data.email.size() > 0;

      allow update: if request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly(['name', 'email', 'city', 'emailFrequency', 'active', 'unsubscribedAt', 'lat', 'lon', 'calendarSystem']);

      allow read:   if false;
      allow delete: if false;
    }

  }
}
