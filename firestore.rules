rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── subscribers ───────────────────────────────────────────────────────────
    // Public create (email sign-up). Self-update for edits / unsubscribe.
    // No client reads — subscriber list is backend-only.
    match /subscribers/{subscriberId} {
      allow create: if request.resource.data.keys().hasAll(['id', 'email', 'active', 'subscribedAt'])
                    && request.resource.data.email is string
                    && request.resource.data.email.size() > 0;

      allow update: if request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly(['name', 'email', 'city', 'emailFrequency', 'active',
                                'unsubscribedAt', 'lat', 'lon', 'calendarSystem']);

      allow read:   if false;
      allow delete: if false;
    }

    // ── devices ───────────────────────────────────────────────────────────────
    // One document per browser that has granted push-notification permission.
    // Public create/update (device opt-in and pref changes).
    // No client reads — device list is backend-only.
    // No client deletes — backend marks inactive; cleanup happens server-side.
    match /devices/{deviceId} {
      allow create: if request.resource.data.keys().hasAll(['token', 'city', 'active', 'updatedAt'])
                    && request.resource.data.token is string
                    && request.resource.data.token.size() > 0;

      allow update: if request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly(['token', 'city', 'lat', 'lon', 'notifPrefs', 'active', 'updatedAt']);

      allow read:   if false;
      allow delete: if false;
    }

  }
}
